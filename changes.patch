diff --git a/style.css b/style.css
index 796062a..8c8fd31 100644
--- a/style.css
+++ b/style.css
@@ -1596,3 +1596,120 @@ html, body {
     padding: 12px 16px;
   }
 }
+
+/* --- Social Proof Carousel --- */
+.social-proof-section {
+  width: 100%;
+  max-width: 600px;
+  margin: 40px auto;
+  padding: 0 20px;
+  overflow: hidden;
+}
+
+.proof-slider {
+  display: flex;
+  gap: 16px;
+  overflow-x: auto;
+  scroll-snap-type: x mandatory;
+  padding: 20px 0;
+  -ms-overflow-style: none;
+  scrollbar-width: none;
+}
+
+.proof-slider::-webkit-scrollbar {
+  display: none;
+}
+
+.social-card {
+  flex: 0 0 280px;
+  scroll-snap-align: center;
+  background: rgba(255, 255, 255, 0.03);
+  border: 1px solid rgba(255, 255, 255, 0.08);
+  border-radius: 24px;
+  padding: 20px;
+  backdrop-filter: blur(10px);
+  -webkit-backdrop-filter: blur(10px);
+  transition: transform 0.3s ease;
+}
+
+.social-card:hover {
+  transform: translateY(-5px);
+  border-color: rgba(255, 255, 255, 0.2);
+}
+
+.card-header {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  margin-bottom: 12px;
+}
+
+.user-avatar {
+  width: 40px;
+  height: 40px;
+  border-radius: 50%;
+  object-fit: cover;
+  border: 1px solid rgba(255, 255, 255, 0.1);
+}
+
+.user-info {
+  flex: 1;
+}
+
+.user-name {
+  font-size: 14px;
+  font-weight: 800;
+  color: #fff;
+  display: block;
+}
+
+.user-handle {
+  font-size: 11px;
+  color: rgba(255, 255, 255, 0.4);
+}
+
+.platform-icon {
+  width: 20px;
+  height: 20px;
+  opacity: 0.6;
+}
+
+.card-content {
+  font-size: 13px;
+  line-height: 1.5;
+  color: rgba(255, 255, 255, 0.85);
+  margin-bottom: 15px;
+}
+
+.card-footer {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  font-size: 11px;
+  color: rgba(255, 255, 255, 0.4);
+  font-weight: 600;
+  border-top: 1px solid rgba(255, 255, 255, 0.05);
+  padding-top: 12px;
+}
+
+/* Platform Colors */
+.card-fb .platform-icon { color: #1877F2; opacity: 1; }
+.card-ig .platform-icon { color: #E4405F; opacity: 1; }
+.card-wa .platform-icon { color: #25D366; opacity: 1; }
+
+.verified-badge {
+  color: #3897f0;
+  width: 14px;
+  height: 14px;
+  display: inline-block;
+  vertical-align: middle;
+  margin-left: 2px;
+}
+
+.wa-bubble {
+  background: rgba(37, 211, 102, 0.05);
+  border-radius: 0 15px 15px 15px;
+  padding: 10px;
+  margin-top: 5px;
+  border-left: 3px solid #25D366;
+}
